<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Universal AI Chat</title>

<!-- Tailwind CDN -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- Marked.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<style>
  html, body {
    height: 100%;
  }

  #app {
    min-height: 100vh;
  }

  .sidebar-transition {
    transition: transform 0.3s ease;
  }

  .code-block pre {
    background: #111827;
    color: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }

  .dark .code-block pre {
    background: #0f172a;
  }

  .typing-cursor::after {
    content: "▋";
    animation: blink 1s infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
</head>

<body class="bg-gray-100 dark:bg-gray-900">

<div id="loading" class="flex items-center justify-center min-h-screen text-gray-500">
  Loading App...
</div>

<div id="app" class="hidden flex min-h-screen">

  <!-- Sidebar -->
  <aside id="sidebar"
    class="sidebar-transition fixed md:static z-30 w-72 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col transform -translate-x-full md:translate-x-0">

    <div class="p-4 flex justify-between items-center border-b dark:border-gray-700">
      <h2 class="font-semibold text-lg dark:text-white">Chats</h2>
      <button id="closeSidebar" class="md:hidden text-gray-500">✕</button>
    </div>

    <button id="newChatBtn"
      class="m-4 p-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
      + New Chat
    </button>

    <div id="chatList" class="flex-1 overflow-y-auto px-2 pb-4"></div>

    <div class="p-4 border-t dark:border-gray-700 space-y-2">
      <button id="settingsBtn" class="w-full text-left text-sm text-gray-600 dark:text-gray-300">⚙ Settings</button>
      <button id="darkToggle" class="w-full text-left text-sm text-gray-600 dark:text-gray-300">🌙 Toggle Dark Mode</button>
    </div>
  </aside>

  <!-- Main -->
  <div class="flex-1 flex flex-col min-h-screen">

    <!-- Top bar -->
    <div class="p-3 border-b dark:border-gray-700 flex items-center bg-white dark:bg-gray-800">
      <button id="openSidebar" class="md:hidden mr-3 text-gray-600 dark:text-gray-300">☰</button>
      <h1 id="chatTitle" class="font-semibold text-gray-800 dark:text-white">New Chat</h1>
    </div>

    <!-- Messages -->
    <div id="messages"
      class="flex-1 overflow-y-auto p-4 space-y-4 bg-gray-50 dark:bg-gray-900">
    </div>

    <!-- Input -->
    <div class="sticky bottom-0 bg-white dark:bg-gray-800 border-t dark:border-gray-700 p-3">
      <div class="flex gap-2">
        <textarea id="messageInput"
          rows="1"
          class="flex-1 resize-none p-2 rounded-lg border dark:bg-gray-700 dark:text-white focus:outline-none"
          placeholder="Type your message..."></textarea>
        <button id="sendBtn"
          class="px-4 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
          Send
        </button>
      </div>
    </div>

  </div>
</div>

<!-- Settings Modal -->
<div id="settingsModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-40">
  <div class="bg-white dark:bg-gray-800 p-6 rounded-lg w-96 space-y-4">
    <h2 class="font-semibold text-lg dark:text-white">Settings</h2>

    <input id="apiKeyInput" type="password"
      placeholder="OpenRouter API Key"
      class="w-full p-2 border rounded dark:bg-gray-700 dark:text-white"/>

    <input id="modelInput" type="text"
      placeholder="Model (default deepseek/deepseek-r1:free)"
      class="w-full p-2 border rounded dark:bg-gray-700 dark:text-white"/>

    <textarea id="systemPromptInput"
      placeholder="System Prompt"
      class="w-full p-2 border rounded dark:bg-gray-700 dark:text-white"></textarea>

    <div class="flex justify-end gap-2">
      <button id="closeSettings" class="px-3 py-1 bg-gray-400 text-white rounded">Cancel</button>
      <button id="saveSettings" class="px-3 py-1 bg-blue-600 text-white rounded">Save</button>
    </div>
  </div>
</div>

<script>
(function() {

  const state = {
    chats: [],
    currentChatId: null,
    apiKey: localStorage.getItem("apiKey") || "",
    model: localStorage.getItem("model") || "deepseek/deepseek-r1:free",
    darkMode: localStorage.getItem("darkMode") === "true"
  };

  const elements = {
    app: document.getElementById("app"),
    loading: document.getElementById("loading"),
    sidebar: document.getElementById("sidebar"),
    openSidebar: document.getElementById("openSidebar"),
    closeSidebar: document.getElementById("closeSidebar"),
    newChatBtn: document.getElementById("newChatBtn"),
    chatList: document.getElementById("chatList"),
    chatTitle: document.getElementById("chatTitle"),
    messages: document.getElementById("messages"),
    messageInput: document.getElementById("messageInput"),
    sendBtn: document.getElementById("sendBtn"),
    settingsBtn: document.getElementById("settingsBtn"),
    settingsModal: document.getElementById("settingsModal"),
    closeSettings: document.getElementById("closeSettings"),
    saveSettings: document.getElementById("saveSettings"),
    apiKeyInput: document.getElementById("apiKeyInput"),
    modelInput: document.getElementById("modelInput"),
    systemPromptInput: document.getElementById("systemPromptInput"),
    darkToggle: document.getElementById("darkToggle")
  };

  function init() {
    try {
      loadChats();
      applyDarkMode();
      bindEvents();
      if (!state.chats.length) createNewChat();
      renderChatList();
      renderMessages();
      elements.loading.classList.add("hidden");
      elements.app.classList.remove("hidden");
    } catch (e) {
      console.error(e);
      elements.loading.innerText = "Initialization Error";
    }
  }

  function bindEvents() {
    elements.newChatBtn.onclick = createNewChat;
    elements.sendBtn.onclick = sendMessage;
    elements.settingsBtn.onclick = openSettings;
    elements.closeSettings.onclick = () => elements.settingsModal.classList.add("hidden");
    elements.saveSettings.onclick = saveSettings;
    elements.darkToggle.onclick = toggleDarkMode;

    elements.openSidebar.onclick = () =>
      elements.sidebar.classList.remove("-translate-x-full");
    elements.closeSidebar.onclick = () =>
      elements.sidebar.classList.add("-translate-x-full");

    elements.messageInput.addEventListener("keydown", function(e) {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
  }

  function createNewChat() {
    const id = Date.now().toString();
    const chat = {
      id,
      title: "New Chat",
      messages: [],
      systemPrompt: ""
    };
    state.chats.push(chat);
    state.currentChatId = id;
    saveChats();
    renderChatList();
    renderMessages();
  }

  function renderChatList() {
    elements.chatList.innerHTML = "";
    state.chats.forEach(chat => {
      const div = document.createElement("div");
      div.className = "p-2 rounded hover:bg-gray-200 dark:hover:bg-gray-700 cursor-pointer flex justify-between";
      div.innerHTML = `
        <span class="truncate">${chat.title}</span>
        <span class="text-xs space-x-1">
          <button data-rename="${chat.id}">✏</button>
          <button data-delete="${chat.id}">🗑</button>
        </span>
      `;
      div.onclick = () => {
        state.currentChatId = chat.id;
        renderMessages();
        renderChatList();
      };
      elements.chatList.appendChild(div);
    });

    document.querySelectorAll("[data-delete]").forEach(btn => {
      btn.onclick = e => {
        e.stopPropagation();
        deleteChat(btn.dataset.delete);
      };
    });

    document.querySelectorAll("[data-rename]").forEach(btn => {
      btn.onclick = e => {
        e.stopPropagation();
        renameChat(btn.dataset.rename);
      };
    });
  }

  function renderMessages() {
    const chat = getCurrentChat();
    if (!chat) return;
    elements.chatTitle.innerText = chat.title;
    elements.messages.innerHTML = "";

    chat.messages.forEach(msg => {
      appendMessage(msg.role, msg.content);
    });

    elements.messages.scrollTop = elements.messages.scrollHeight;
  }

  function appendMessage(role, content) {
    const div = document.createElement("div");
    div.className = role === "user"
      ? "text-right"
      : "text-left";

    const bubble = document.createElement("div");
    bubble.className =
      role === "user"
        ? "inline-block bg-blue-600 text-white p-3 rounded-lg max-w-xl"
        : "inline-block bg-gray-200 dark:bg-gray-700 dark:text-white p-3 rounded-lg max-w-xl code-block";

    bubble.innerHTML = marked.parse(content);
    div.appendChild(bubble);
    elements.messages.appendChild(div);
  }

  async function sendMessage() {
    const text = elements.messageInput.value.trim();
    if (!text) return;
    if (!state.apiKey) return alert("Set API key in settings.");

    const chat = getCurrentChat();
    chat.messages.push({ role: "user", content: text });
    elements.messageInput.value = "";
    renderMessages();
    saveChats();

    const aiDiv = document.createElement("div");
    aiDiv.className = "text-left";
    const bubble = document.createElement("div");
    bubble.className = "inline-block bg-gray-200 dark:bg-gray-700 dark:text-white p-3 rounded-lg max-w-xl typing-cursor";
    aiDiv.appendChild(bubble);
    elements.messages.appendChild(aiDiv);

    try {
      const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
        method: "POST",
        headers: {
          "Authorization": "Bearer " + state.apiKey,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          model: state.model,
          messages: [
            ...(chat.systemPrompt ? [{ role: "system", content: chat.systemPrompt }] : []),
            ...chat.messages
          ],
          stream: true
        })
      });

      const reader = response.body.getReader();
      const decoder = new TextDecoder("utf-8");
      let fullText = "";

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        const chunk = decoder.decode(value);
        const lines = chunk.split("\n").filter(l => l.startsWith("data: "));
        for (let line of lines) {
          const json = line.replace("data: ", "");
          if (json === "[DONE]") break;
          try {
            const parsed = JSON.parse(json);
            const token = parsed.choices?.[0]?.delta?.content;
            if (token) {
              fullText += token;
              bubble.innerHTML = marked.parse(fullText);
              elements.messages.scrollTop = elements.messages.scrollHeight;
            }
          } catch {}
        }
      }

      bubble.classList.remove("typing-cursor");
      chat.messages.push({ role: "assistant", content: fullText });
      saveChats();

    } catch (err) {
      bubble.classList.remove("typing-cursor");
      bubble.innerText = "Error: " + err.message;
    }
  }

  function getCurrentChat() {
    return state.chats.find(c => c.id === state.currentChatId);
  }

  function deleteChat(id) {
    state.chats = state.chats.filter(c => c.id !== id);
    if (!state.chats.length) createNewChat();
    else state.currentChatId = state.chats[0].id;
    saveChats();
    renderChatList();
    renderMessages();
  }

  function renameChat(id) {
    const name = prompt("Rename chat:");
    if (!name) return;
    const chat = state.chats.find(c => c.id === id);
    if (chat) chat.title = name;
    saveChats();
    renderChatList();
    renderMessages();
  }

  function openSettings() {
    elements.apiKeyInput.value = state.apiKey;
    elements.modelInput.value = state.model;
    elements.systemPromptInput.value = getCurrentChat()?.systemPrompt || "";
    elements.settingsModal.classList.remove("hidden");
  }

  function saveSettings() {
    state.apiKey = elements.apiKeyInput.value.trim();
    state.model = elements.modelInput.value.trim() || "deepseek/deepseek-r1:free";
    const chat = getCurrentChat();
    if (chat) chat.systemPrompt = elements.systemPromptInput.value.trim();
    localStorage.setItem("apiKey", state.apiKey);
    localStorage.setItem("model", state.model);
    saveChats();
    elements.settingsModal.classList.add("hidden");
  }

  function saveChats() {
    localStorage.setItem("chats", JSON.stringify(state.chats));
  }

  function loadChats() {
    const saved = localStorage.getItem("chats");
    if (saved) {
      state.chats = JSON.parse(saved);
      state.currentChatId = state.chats[0]?.id || null;
    }
  }

  function toggleDarkMode() {
    state.darkMode = !state.darkMode;
    localStorage.setItem("darkMode", state.darkMode);
    applyDarkMode();
  }

  function applyDarkMode() {
    if (state.darkMode)
      document.documentElement.classList.add("dark");
    else
      document.documentElement.classList.remove("dark");
  }

  init();

})();
</script>

</body>
</html>
